[global]
font = DejaVu Sans 10
frame_width = 2
frame_color = "#5e81ac"
corner_radius = 6

[urgency_low]
background = "#2e3440"
foreground = "#d8dee9"
timeout = 5

[urgency_normal]
background = "#3b4252"
foreground = "#eceff4"
timeout = 10

[urgency_critical]
background = "#bf616a"
foreground = "#eceff4"
timeout = 0
