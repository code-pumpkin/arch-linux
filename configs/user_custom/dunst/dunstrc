[global]
monitor = 0
follow = mouse
width = 450
height = (0, 300)
origin = top-right
offset = (15, 50)
notification_limit = 5
progress_bar = true
indicate_hidden = yes
transparency = 10
separator_height = 2
padding = 16
horizontal_padding = 18
frame_width = 2
frame_color = "#F0C674"
separator_color = frame
sort = yes
idle_threshold = 120
font = monospace 14
line_height = 4
markup = full
format = "<b>%s</b>\n%b"
alignment = left
vertical_alignment = center
show_age_threshold = 60
ellipsize = middle
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
icon_position = left
max_icon_size = 48
corner_radius = 8
mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all

[urgency_low]
background = "#282A2E"
foreground = "#C5C8C6"
timeout = 5

[urgency_normal]
background = "#282A2E"
foreground = "#C5C8C6"
timeout = 8
override_pause_level = 30
script = ~/.config/dunst/notify-sound.sh

[urgency_critical]
background = "#A54242"
foreground = "#C5C8C6"
frame_color = "#A54242"
timeout = 0
override_pause_level = 60
script = ~/.config/dunst/notify-sound.sh
