# Enable Powerlevel10k instant prompt (must stay at top)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --- PATH (all in one place, no exports needed after login) ---
export PATH="$HOME/.local/bin:$HOME/.opencode/bin:$HOME/.cargo/bin:$PATH"

# --- Environment ---
export EDITOR=nvim
export VISUAL=nvim
export LANG=en_US.UTF-8
export BROWSER=librewolf
export TERMINAL=kitty

# XDG
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# API keys
export ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"
export OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
export OPENAI_BASE_URL="https://api.openai.com/v1"

# Dynamic AI base URL — probe local servers
if [[ -x "$HOME/.local/bin/resolve-ai-base-url.sh" ]]; then
  export ANTHROPIC_BASE_URL="$($HOME/.local/bin/resolve-ai-base-url.sh)"
else
  export ANTHROPIC_BASE_URL="http://192.168.1.193:8000/v1"
fi

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins (only what's useful, no bloat)
plugins=(
  git              # git aliases & completions
  sudo             # press Esc twice to prefix last command with sudo
  extract          # `extract <archive>` — handles any archive format
  z                # jump to frecent directories
  fzf              # fuzzy finder integration
  rust             # rustc/cargo completions
  colored-man-pages # colorized man pages
  command-not-found # suggest package when command not found
  dirhistory       # Alt+Left/Right to navigate dir history
  copypath         # `copypath` copies current dir to clipboard
  aliases          # `als` to list aliases
)

# OMZ settings
HIST_STAMPS="yyyy-mm-dd"
COMPLETION_WAITING_DOTS=true
DISABLE_UNTRACKED_FILES_DIRTY=true  # faster git status in large repos

source $ZSH/oh-my-zsh.sh

# --- External plugins (pacman-installed) ---
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# --- zoxide (smarter cd) ---
eval "$(zoxide init zsh)"

# --- fzf config ---
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline'

# --- Aliases ---
alias ls='eza --icons --group-directories-first'
alias ll='eza -la --icons --group-directories-first'
alias lt='eza -laT --icons --level=2'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'
alias v='nvim'
alias vi='nvim'
alias vim='nvim'
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias mkdir='mkdir -pv'
alias df='df -h'
alias du='du -sh'
alias free='free -h'
alias ports='ss -tulnp'
alias myip='curl -s ifconfig.me'
alias reload='source ~/.zshrc'

# passkeyd
alias passkeys='sudo passkeyd-manager'
alias passkeyd-logs='journalctl -u passkeyd -f'
alias passkeyd-rebuild='cd ~/passkeyd-src && cargo build --release -p passkeyd && sudo systemctl stop passkeyd && sudo cp target/release/passkeyd /usr/bin/passkeyd && sudo systemctl start passkeyd && cd -'

# --- History ---
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY

# --- Key bindings ---
bindkey '^[[A' history-substring-search-up 2>/dev/null
bindkey '^[[B' history-substring-search-down 2>/dev/null

# --- Name checker hook (AI filename suggestions) ---
[ -f "$HOME/.local/share/name-checker/hook.zsh" ] && source "$HOME/.local/share/name-checker/hook.zsh"

# --- Sweep stray files/dirs from ~ on login + every cd into ~ ---
home_sweep() { [[ "$PWD" == "$HOME" ]] && "$HOME/.local/bin/home-sweep.sh" 2>/dev/null; }
chpwd_functions+=(home_sweep)
if [[ -o login ]] && [[ -x "$HOME/.local/bin/home-sweep.sh" ]]; then
  "$HOME/.local/bin/home-sweep.sh" 2>/dev/null
fi

# --- Powerlevel10k config ---
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# --- Greeting ---
if [[ -o interactive ]] && command -v fastfetch &>/dev/null; then
  fastfetch
fi
